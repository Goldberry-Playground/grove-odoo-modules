<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">

        <!--
            Grove Product Attributes (Variants)
            =====================================
            Size and Container attributes for nursery plant variants.
            Each combination creates a separate variant that tracks
            inventory independently.
        -->

        <!-- ── Attribute: Size ───────────────────────────────────── -->

        <record id="attr_size" model="product.attribute">
            <field name="name">Size</field>
            <field name="display_type">radio</field>
            <field name="create_variant">always</field>
        </record>

        <record id="attr_size_1gal" model="product.attribute.value">
            <field name="name">1 gal</field>
            <field name="attribute_id" ref="attr_size" />
            <field name="sequence">10</field>
        </record>

        <record id="attr_size_3gal" model="product.attribute.value">
            <field name="name">3 gal</field>
            <field name="attribute_id" ref="attr_size" />
            <field name="sequence">20</field>
        </record>

        <record id="attr_size_5gal" model="product.attribute.value">
            <field name="name">5 gal</field>
            <field name="attribute_id" ref="attr_size" />
            <field name="sequence">30</field>
        </record>

        <record id="attr_size_10gal" model="product.attribute.value">
            <field name="name">10 gal</field>
            <field name="attribute_id" ref="attr_size" />
            <field name="sequence">40</field>
        </record>

        <record id="attr_size_bare_root" model="product.attribute.value">
            <field name="name">Bare Root</field>
            <field name="attribute_id" ref="attr_size" />
            <field name="sequence">50</field>
        </record>

        <!-- ── Attribute: Container ──────────────────────────────── -->

        <record id="attr_container" model="product.attribute">
            <field name="name">Container</field>
            <field name="display_type">radio</field>
            <field name="create_variant">always</field>
        </record>

        <record id="attr_container_nursery_pot" model="product.attribute.value">
            <field name="name">Nursery Pot</field>
            <field name="attribute_id" ref="attr_container" />
            <field name="sequence">10</field>
        </record>

        <record id="attr_container_ceramic" model="product.attribute.value">
            <field name="name">Ceramic Pot</field>
            <field name="attribute_id" ref="attr_container" />
            <field name="sequence">20</field>
        </record>

        <record id="attr_container_burlap" model="product.attribute.value">
            <field name="name">Burlap Ball</field>
            <field name="attribute_id" ref="attr_container" />
            <field name="sequence">30</field>
        </record>

        <record id="attr_container_bare_root" model="product.attribute.value">
            <field name="name">Bare Root</field>
            <field name="attribute_id" ref="attr_container" />
            <field name="sequence">40</field>
        </record>

    </data>
</odoo>
